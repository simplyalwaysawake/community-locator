<% content_for :head do %>
  <%= stylesheet_link_tag "leaflet/leaflet", "leaflet/leaflet-markercluster", "leaflet/leaflet-markercluster-default", "data-turbo-track": "reload" %>
<% end %>
<%
  map_center = { lat: @location.latitude, lng: @location.longitude }.to_json
  map_markers = @map_community.map { |u|
    { lat: u.location.latitude, lng: u.location.longitude,
      name: display_name(u), city: short_address(u.location) }
  }.to_json
  map_icons = {
    icon: asset_path('leaflet/images/marker-icon.png'),
    icon2x: asset_path('leaflet/images/marker-icon-2x.png'),
    shadow: asset_path('leaflet/images/marker-shadow.png')
  }.to_json
%>
<%= render layout: "community/frame", locals: { active: :map } do %>
<div data-controller="map"
     data-map-center-value="<%= map_center %>"
     data-map-markers-value="<%= map_markers %>"
     data-map-icons-value="<%= map_icons %>"
     data-map-range-value="<%= @range %>"
     class="h-[900px] max-h-[80vh] rounded-lg overflow-hidden"></div>
<% end %>

{
  "stack": "heroku-26",
  "buildpacks": [{ "url": "heroku/ruby" }],
  "addons": ["heroku-postgresql:mini"],
  "env": {
    "HERE_API_KEY": { "required": true },
    "RECAPTCHA_SITE_KEY": { "required": true },
    "RECAPTCHA_SECRET_KEY": { "required": true }
  },
  "environments": {
    "test": {
      "addons": ["heroku-postgresql:in-dyno"],
      "scripts": {
        "test": "bundle exec rake validate"
      }
    },
    "review": {
      "scripts": {
        "postdeploy": "bundle exec rake db:seed"
      },
      "features": [
        "runtime-dyno-metadata"
      ]
    }
  }
}
